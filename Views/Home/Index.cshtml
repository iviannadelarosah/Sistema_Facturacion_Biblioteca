@{
    ViewData["Title"] = "Inicio";
}

<div class="container py-4">
    <div class="text-center mb-4 hero-section">
        <h1 class="fw-bold" style="color:#4D7EA8;">Bienvenido al Sistema de Facturación Biblioteca</h1>
        <p class="lead" style="color:#555;">Gestión eficiente, segura y elegante para tu biblioteca</p>

        <div class="d-flex justify-content-center gap-2 mt-4">
            <div style="width:40px; height:120px; background:#880D1E; border-radius:4px;"></div>
            <div style="width:40px; height:140px; background:#DD2D4A; border-radius:4px;"></div>
            <div style="width:40px; height:100px; background:#F26A8D; border-radius:4px;"></div>
            <div style="width:40px; height:130px; background:#CBEEF3; border-radius:4px;"></div>
        </div>
        <small class="d-none">Ilustración simbólica de biblioteca</small>
    </div>

    <div class="row text-center mb-4">
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100 border-0" style="background-color:#F0F7EE;">
                <div class="card-body">
                    <i class="bi bi-journal-bookmark-fill display-4 mb-3" style="color:#4D7EA8;"></i>
                    <h4 class="fw-bold" style="color:#4D7EA8;">Organización</h4>
                    <p class="text-muted">Mantén tus servicios y registros ordenados con facilidad.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100 border-0" style="background-color:#F0F7EE;">
                <div class="card-body">
                    <i class="bi bi-credit-card-2-front display-4 mb-3" style="color:#4D7EA8;"></i>
                    <h4 class="fw-bold" style="color:#4D7EA8;">Control</h4>
                    <p class="text-muted">Administra pagos y facturas de manera clara y segura.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card shadow-sm h-100 border-0" style="background-color:#F0F7EE;">
                <div class="card-body">
                    <i class="bi bi-shield-lock-fill display-4 mb-3" style="color:#4D7EA8;"></i>
                    <h4 class="fw-bold" style="color:#4D7EA8;">Seguridad</h4>
                    <p class="text-muted">Accede con roles definidos: Admin y Empleado.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row text-center mb-4 stats">
        <div class="col-md-3"><h2 style="color:#4D7EA8;">120+</h2><p class="text-muted">Servicios</p></div>
        <div class="col-md-3"><h2 style="color:#F26A8D;">350+</h2><p class="text-muted">Facturas</p></div>
        <div class="col-md-3"><h2 style="color:#4D7EA8;">500+</h2><p class="text-muted">Pagos</p></div>
        <div class="col-md-3"><h2 style="color:#F26A8D;">99%</h2><p class="text-muted">Satisfacción</p></div>
    </div>

    <div class="text-center">
        <blockquote class="blockquote" style="color:#4D7EA8;">
            <p>“El conocimiento es la mejor inversión que puedes hacer.”</p>
        </blockquote>
    </div>
</div>