@model Sistema_Facturacion_Biblioteca.Models.Servicio

<h2>Crear Servicio</h2>

<form asp-controller="Servicios" asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="NombreServicio"></label>
        <input asp-for="NombreServicio" class="form-control" />
        <span asp-validation-for="NombreServicio" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Precio"></label>
        <input asp-for="Precio" class="form-control" />
        <span asp-validation-for="Precio" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-controller="Home" asp-action="Servicios" class="btn btn-secondary">Cancelar</a>
</form>