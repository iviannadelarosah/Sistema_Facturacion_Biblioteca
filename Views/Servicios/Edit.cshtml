@model Sistema_Facturacion_Biblioteca.Models.Servicio

<h2>Editar Servicio</h2>

<form asp-controller="Servicios" asp-action="Edit" method="post">
    <input type="hidden" asp-for="IdServicio" />

    <div class="form-group">
        <label asp-for="NombreServicio"></label>
        <input asp-for="NombreServicio" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Precio"></label>
        <input asp-for="Precio" class="form-control" />
    </div>

    <button type="submit" class="btn btn-warning">Actualizar</button>

    <a asp-controller="Home" asp-action="Servicios" class="btn btn-secondary">Cancelar</a>
</form>